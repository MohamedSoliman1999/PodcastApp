<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        Night override: the splash background matches the dark window background
        so there is no flash of light when the user has system dark mode on.
    -->
    <style name="Theme.PodcastApp.Splash" parent="Theme.SplashScreen">
        <item name="postSplashScreenTheme">@style/Theme.PodcastApp</item>
        <item name="windowSplashScreenBackground">@color/background</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
    </style>
</resources>